<?xml version="1.0" encoding="utf-8"?>
<!-- Root: LinearLayout (vertical) — Layout ke-1 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- App Bar -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#3F51B5"
        android:text="Form Identitas Mahasiswa"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:padding="16dp"
        android:elevation="4dp" />

    <!-- Scroll View agar bisa scroll jika konten panjang -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <!-- Inner LinearLayout (vertical) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="2dp">

            <!-- ===== Nama Lengkap ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Lengkap"
                android:textSize="14sp"
                android:textColor="#555555"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etNama"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Masukkan nama lengkap..."
                android:inputType="textPersonName"
                android:padding="10dp"
                android:background="@drawable/edittext_border"
                android:layout_marginBottom="16dp" />

            <!-- ===== Jenis Kelamin ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jenis Kelamin"
                android:textSize="14sp"
                android:textColor="#555555"
                android:layout_marginBottom="4dp" />

            <!--
                RadioGroup menggunakan orientation horizontal
                → Ini adalah Layout ke-2 (LinearLayout horizontal di dalam vertical)
            -->
            <RadioGroup
                android:id="@+id/rgJenisKelamin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#E8EAF6"
                android:padding="8dp"
                android:layout_marginBottom="16dp">

                <RadioButton
                    android:id="@+id/rbLakiLaki"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Laki-laki"
                    android:layout_marginEnd="16dp"
                    android:buttonTint="#3F51B5" />

                <RadioButton
                    android:id="@+id/rbPerempuan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Perempuan"
                    android:buttonTint="#3F51B5" />

            </RadioGroup>

            <!-- ===== Hobi (CheckBox) ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hobi"
                android:textSize="14sp"
                android:textColor="#555555"
                android:layout_marginBottom="4dp" />

            <CheckBox
                android:id="@+id/cbMembaca"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Membaca"
                android:buttonTint="#3F51B5" />

            <CheckBox
                android:id="@+id/cbCoding"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Coding"
                android:buttonTint="#3F51B5" />

            <CheckBox
                android:id="@+id/cbOlahraga"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Olahraga"
                android:buttonTint="#3F51B5"
                android:layout_marginBottom="20dp" />

            <!-- ===== Tombol Tampilkan ===== -->
            <Button
                android:id="@+id/btnTampilkan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tampilkan"
                android:backgroundTint="#3F51B5"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <!-- ===== Hasil TextView ===== -->
            <TextView
                android:id="@+id/tvHasil"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Hasil akan muncul di sini..."
                android:textColorHint="#BBBBBB"
                android:padding="12dp"
                android:background="@drawable/textview_border"
                android:textSize="14sp"
                android:textColor="#333333"
                android:lineSpacingExtra="6dp"
                android:minHeight="80dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
